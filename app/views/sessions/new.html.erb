<% provide(:title, "login") %>
<h1>login</h1>
<%= form_with(url: login_path, scope: :session) do |f| %>

  <div class="mb-3">
    <%= f.label :email, class: "form-label" %>
    <%= f.email_field :email, class: "form-control", placeholder: "Enter your email" %>
  </div>

  <div class="mb-3">
    <%= f.label :password, class: "form-label" %>
    <%= f.password_field :password, class: "form-control", placeholder: "Enter password" %>
  </div>

  <div class="form-check">
  <%= f.check_box :remember_me, class: "form-check-input", id: "remember_me" %>
  <%= f.label :remember_me, "Remember me on this computer", class: "form-check-label" %>
</div>

  <div class="d-grid">
    <%= f.submit "Login!", class: "btn btn-primary btn-lg" %>
  </div>
<% end %>
