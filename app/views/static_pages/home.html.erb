<% if logged_in? %>
  <div class="container mt-4">
    <div class="row">

      <!-- 左サイド -->
      <aside class="col-md-4 mb-4">

        <div class="card shadow-sm mb-3 p-3">
          <section class="user_info">
            <%= render 'shared/user_info' %>
          </section>
        </div>

        <div class="card shadow-sm p-3">
          <section class="micropost_form">
            <%= render 'shared/micropost_form' %>
          </section>
        </div>

      </aside>

      <!-- 右フィード -->
      <div class="col-md-8">

        <div class="card shadow-sm p-3">
          <h5 class="mb-3 fw-bold">Micropost Feed</h5>

          <%= render 'shared/feed' %>
        </div>

      </div>

    </div>
  </div>

<% else %>
  <div class="container mt-5 text-center">

    <div class="p-5 mb-4 bg-light rounded-3 shadow-sm">
      <h1 class="display-5 fw-bold">Welcome to the Sample App</h1>

      <p class="lead">
        This is the home page for the
        <a href="https://railstutorial.jp/" class="text-decoration-none">
          Ruby on Rails Tutorial
        </a>
        sample application.
      </p>

      <%= link_to "Sign up now!", signup_path,
          class: "btn btn-primary btn-lg mt-3" %>
    </div>

    <div class="mt-3">
      <%= link_to image_tag("rails.svg", alt: "Rails logo", width: "200px", class: "img-fluid"),
                  "https://rubyonrails.org/" %>
    </div>

  </div>

<% end %>